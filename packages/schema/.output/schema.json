{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "meta": {
            "type": "object",
            "properties": {
                "name": {
                    "$ref": "#/$defs/__schema0"
                },
                "github": {
                    "$ref": "#/$defs/__schema1"
                }
            },
            "required": [
                "name",
                "github"
            ],
            "additionalProperties": false,
            "description": "Metadata about this file, such as its name and repository source"
        },
        "entries": {
            "description": "A node representing a media entry within the universe tree. It can be a root node, a series, a movie, or any related media.",
            "$ref": "#/$defs/__schema2"
        }
    },
    "required": [
        "meta"
    ],
    "additionalProperties": false,
    "$defs": {
        "__schema0": {
            "type": "string"
        },
        "__schema1": {
            "type": "string",
            "format": "uri"
        },
        "__schema2": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/__schema3"
            }
        },
        "__schema3": {
            "oneOf": [
                {
                    "type": "object",
                    "properties": {
                        "$id": {
                            "$ref": "#/$defs/__schema4"
                        },
                        "$reference": {
                            "$ref": "#/$defs/__schema6"
                        },
                        "name": {
                            "$ref": "#/$defs/__schema9"
                        },
                        "kind": {
                            "type": "string",
                            "const": "$root"
                        },
                        "childs": {
                            "description": "Direct child entries of this node. Entries at the same depth level are interpreted as seasons of the same series. Nested children (children of children) represent spin-offs, side stories, or other extended universe content",
                            "$ref": "#/$defs/__schema10"
                        },
                        "$related": {
                            "description": "Related entries that share the same universe or are connected conceptually, but are not part of the direct hierarchy.",
                            "$ref": "#/$defs/__schema11"
                        }
                    },
                    "required": [
                        "name",
                        "kind"
                    ],
                    "additionalProperties": false
                },
                {
                    "type": "object",
                    "properties": {
                        "$id": {
                            "$ref": "#/$defs/__schema4"
                        },
                        "$reference": {
                            "$ref": "#/$defs/__schema6"
                        },
                        "name": {
                            "$ref": "#/$defs/__schema9"
                        },
                        "kind": {
                            "default": "anime",
                            "$ref": "#/$defs/__schema12"
                        },
                        "chronology": {
                            "type": "string"
                        },
                        "status": {
                            "description": "Tracking information such as watch progress, reading progress, and personal notes",
                            "$ref": "#/$defs/__schema13"
                        },
                        "childs": {
                            "description": "Direct child entries of this node. Entries at the same depth level are interpreted as seasons of the same series. Nested children (children of children) represent spin-offs, side stories, or other extended universe content",
                            "$ref": "#/$defs/__schema23"
                        },
                        "$related": {
                            "description": "Related entries that share the same universe or are connected conceptually, but are not part of the direct hierarchy.",
                            "$ref": "#/$defs/__schema24"
                        }
                    },
                    "required": [
                        "name",
                        "kind"
                    ],
                    "additionalProperties": false
                },
                {
                    "type": "object",
                    "properties": {
                        "$id": {
                            "$ref": "#/$defs/__schema4"
                        },
                        "$reference": {
                            "$ref": "#/$defs/__schema6"
                        },
                        "name": {
                            "$ref": "#/$defs/__schema9"
                        },
                        "kind": {
                            "anyOf": [
                                {
                                    "type": "string",
                                    "const": "manga",
                                    "description": "Japanese"
                                },
                                {
                                    "type": "string",
                                    "const": "manhua",
                                    "description": "Chinese"
                                },
                                {
                                    "type": "string",
                                    "const": "manhwa",
                                    "description": "Korean"
                                },
                                {
                                    "type": "string",
                                    "const": "light-novel"
                                },
                                {
                                    "type": "string",
                                    "const": "web-novel"
                                },
                                {
                                    "type": "string",
                                    "const": "other"
                                }
                            ]
                        },
                        "status": {
                            "description": "Tracking information such as watch progress, reading progress, and personal notes",
                            "$ref": "#/$defs/__schema25"
                        },
                        "adapted_until": {
                            "description": "Shows how far this entry has been adapted into another medium",
                            "$ref": "#/$defs/__schema28"
                        },
                        "childs": {
                            "description": "Direct child entries of this node. Entries at the same depth level are interpreted as seasons of the same series. Nested children (children of children) represent spin-offs, side stories, or other extended universe content",
                            "$ref": "#/$defs/__schema33"
                        },
                        "$related": {
                            "description": "Related entries that share the same universe or are connected conceptually, but are not part of the direct hierarchy.",
                            "$ref": "#/$defs/__schema34"
                        }
                    },
                    "required": [
                        "name",
                        "kind"
                    ],
                    "additionalProperties": false
                }
            ]
        },
        "__schema4": {
            "description": "Stable identifier used for referencing this entry across the dataset",
            "$ref": "#/$defs/__schema5"
        },
        "__schema5": {
            "type": "string"
        },
        "__schema6": {
            "description": "References to other entries by id. Use this field when only a link is needed instead of embedding the full object",
            "$ref": "#/$defs/__schema7"
        },
        "__schema7": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "$id": {
                        "type": "string",
                        "description": "Stable identifier used for referencing this entry across the dataset"
                    },
                    "relation": {
                        "description": "Describe the relation between entries",
                        "$ref": "#/$defs/__schema8"
                    }
                },
                "required": [
                    "$id"
                ],
                "additionalProperties": false
            }
        },
        "__schema8": {
            "type": "array",
            "items": {
                "anyOf": [
                    {
                        "type": "string",
                        "const": "prequel",
                        "description": "The referenced entry is a prequel to the current entry"
                    },
                    {
                        "type": "string",
                        "const": "sequel",
                        "description": "The referenced entry is a sequel to the current entry"
                    },
                    {
                        "type": "string",
                        "const": "universe",
                        "description": "The current entry shares the same fictional universe as the referenced entry"
                    },
                    {
                        "type": "string",
                        "const": "author",
                        "description": "The current entry shares the same author as the referenced entry"
                    },
                    {
                        "type": "string",
                        "const": "unknown",
                        "description": "The relationship is known to exist but has not been classified"
                    }
                ]
            }
        },
        "__schema9": {
            "type": "string"
        },
        "__schema10": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/__schema3"
            }
        },
        "__schema11": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/__schema3"
            }
        },
        "__schema12": {
            "anyOf": [
                {
                    "type": "string",
                    "const": "anime",
                    "description": "Japanese"
                },
                {
                    "type": "string",
                    "const": "donghua",
                    "description": "Chinese"
                },
                {
                    "type": "string",
                    "const": "aeni",
                    "description": "Korean"
                },
                {
                    "type": "string",
                    "const": "ova"
                },
                {
                    "type": "string",
                    "const": "movie"
                }
            ]
        },
        "__schema13": {
            "type": "object",
            "properties": {
                "watched": {
                    "$ref": "#/$defs/__schema14"
                },
                "favorite": {
                    "$ref": "#/$defs/__schema16"
                },
                "rating": {
                    "$ref": "#/$defs/__schema18"
                },
                "comments": {
                    "$ref": "#/$defs/__schema20"
                },
                "episode": {
                    "description": "Last watched episode of the current entry",
                    "$ref": "#/$defs/__schema22"
                }
            },
            "additionalProperties": false
        },
        "__schema14": {
            "description": "Indicates whether this entry has been watched",
            "$ref": "#/$defs/__schema15"
        },
        "__schema15": {
            "type": "boolean"
        },
        "__schema16": {
            "description": "Marks this entry as a personal favorite",
            "$ref": "#/$defs/__schema17"
        },
        "__schema17": {
            "type": "boolean"
        },
        "__schema18": {
            "description": "Personal rating for the current entry",
            "$ref": "#/$defs/__schema19"
        },
        "__schema19": {
            "type": "number",
            "exclusiveMinimum": 0
        },
        "__schema20": {
            "description": "Optional free-form notes or comments",
            "$ref": "#/$defs/__schema21"
        },
        "__schema21": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            ]
        },
        "__schema22": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "number",
                    "exclusiveMinimum": 0
                }
            ]
        },
        "__schema23": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/__schema3"
            }
        },
        "__schema24": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/__schema3"
            }
        },
        "__schema25": {
            "type": "object",
            "properties": {
                "watched": {
                    "$ref": "#/$defs/__schema14"
                },
                "favorite": {
                    "$ref": "#/$defs/__schema16"
                },
                "rating": {
                    "$ref": "#/$defs/__schema18"
                },
                "comments": {
                    "$ref": "#/$defs/__schema20"
                },
                "completed": {
                    "description": "Wether the current entry has been fully completed or not",
                    "$ref": "#/$defs/__schema26"
                },
                "chapter": {
                    "description": "Last readed chapter of the current entry",
                    "$ref": "#/$defs/__schema27"
                }
            },
            "additionalProperties": false
        },
        "__schema26": {
            "type": "boolean"
        },
        "__schema27": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "number",
                    "exclusiveMinimum": 0
                }
            ]
        },
        "__schema28": {
            "type": "object",
            "properties": {
                "kind": {
                    "$ref": "#/$defs/__schema12"
                },
                "chapter": {
                    "description": "The last source chapter covered by the adaptation",
                    "$ref": "#/$defs/__schema29"
                },
                "volume": {
                    "description": "The last source volume covered by the adaptation",
                    "$ref": "#/$defs/__schema30"
                },
                "episode": {
                    "description": "The corresponding episode where the adaptation currently ends",
                    "$ref": "#/$defs/__schema31"
                },
                "arc": {
                    "description": "The last story arc covered by the adaptation",
                    "$ref": "#/$defs/__schema32"
                }
            },
            "additionalProperties": false
        },
        "__schema29": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "number",
                    "exclusiveMinimum": 0
                }
            ]
        },
        "__schema30": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "number",
                    "exclusiveMinimum": 0
                }
            ]
        },
        "__schema31": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "number",
                    "exclusiveMinimum": 0
                }
            ]
        },
        "__schema32": {
            "type": "string"
        },
        "__schema33": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/__schema3"
            }
        },
        "__schema34": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/__schema3"
            }
        }
    }
}